#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Screen Recorder
# =============================================================================
# Description : Toggle screen recording with wf-recorder. Select area with slurp
#               on first run, stop recording on second run.
# Author      : Maximocruz (@zenith-56)
# License     : MIT
#
# Usage:
#   zenith-screen-recorder
#     First run: Select area and start recording
#     Second run: Stop recording
# =============================================================================

set -euo pipefail

VIDEO_DIR="$HOME/Videos"
FILENAME="$VIDEO_DIR/ScreenRecord_$(date +%Y%m%d_%H%M%S).mp4"
RECORDING_PID=""

cleanup() {
    if [ -n "$RECORDING_PID" ] && kill -0 "$RECORDING_PID" 2>/dev/null; then
        kill -INT "$RECORDING_PID" 2>/dev/null || true
        wait "$RECORDING_PID" 2>/dev/null || true
    fi
}

trap cleanup EXIT INT TERM

if ! command -v wf-recorder &>/dev/null; then
    echo "wf-recorder not found"
    exit 1
fi

if ! command -v slurp &>/dev/null; then
    echo "slurp not found"
    exit 1
fi

mkdir -p "$VIDEO_DIR"

if pgrep -x "wf-recorder" >/dev/null; then
    pkill -INT wf-recorder
    notify-send "Recording" "Recording finished and saved to $VIDEO_DIR" -i video-display 2>/dev/null || true
else
    notify-send "Recording" "Select area to record..." -i video-camera-symbolic 2>/dev/null || true

    GEOM=$(slurp 2>/dev/null) || {
        notify-send "Recording" "Selection cancelled" -i dialog-warning 2>/dev/null || true
        exit 0
    }

    if [ -n "$GEOM" ]; then
        wf-recorder -g "$GEOM" -p yuv420p -f "$FILENAME" &
        RECORDING_PID=$!
        wait "$RECORDING_PID" || true
    else
        notify-send "Recording" "No area selected" -i dialog-warning 2>/dev/null || true
    fi
fi
