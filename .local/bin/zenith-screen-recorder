#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Screen Recorder
# =============================================================================
# Description : Toggle screen recording with wf-recorder. Select area with slurp
#               on first run, stop recording on second run.
# Author      : Maximocruz (@zenith-56)
# License     : MIT
#
# Usage:
#   zenith-screen-recorder
#     First run: Select area and start recording
#     Second run: Stop recording
# =============================================================================

set -euo pipefail

VIDEO_DIR="$HOME/Videos"
PID_FILE="/tmp/zenith-screen-recorder.pid"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

if ! command -v wf-recorder &>/dev/null; then
    echo "wf-recorder not found" >&2
    exit 1
fi

if ! command -v slurp &>/dev/null; then
    echo "slurp not found" >&2
    exit 1
fi

mkdir -p "$VIDEO_DIR"

stop_recording() {
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill -INT "$pid" 2>/dev/null
            wait "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
    elif pgrep -x "wf-recorder" >/dev/null; then
        pkill -INT wf-recorder
    fi
    zen_notify "Recording" "Recording finished and saved to $VIDEO_DIR"
}

start_recording() {
    local filename="$VIDEO_DIR/ScreenRecord_$(date +%Y%m%d_%H%M%S).mp4"

    zen_notify "Recording" "Select area to record..."

    local geom
    geom=$(slurp 2>/dev/null) || {
        zen_notify "Recording" "Selection cancelled"
        exit 0
    }

    if [[ -n "$geom" ]]; then
        wf-recorder -g "$geom" -p yuv420p -f "$filename" &
        echo $! > "$PID_FILE"
        zen_notify "Recording" "Recording started ($geom)"
    else
        zen_notify "Recording" "No area selected"
    fi
}

if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    stop_recording
else
    rm -f "$PID_FILE"
    start_recording
fi
