#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - AUR Package Install
# =============================================================================
# Interactive AUR package installation using fzf and yay

set -euo pipefail

if ! command -v yay &>/dev/null; then
    echo "yay not found"
    exit 1
fi

if ! command -v fzf &>/dev/null; then
    echo "fzf not found"
    exit 1
fi

fzf_args=(
  --style minimal
  --multi
  --preview 'yay -Siia {1}'
  --preview-window 'right:75%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --bind 'alt-b:change-preview:yay -Gpa {1} | tail -n +5'
  --bind 'alt-B:change-preview:yay -Siia {1}'
  --color 'pointer:green,marker:green'
)

pkg_names=$(yay -Slqa | fzf "${fzf_args[@]}") || exit 0

if [[ -n "$pkg_names" ]]; then
  echo "$pkg_names" | sed 's/^/aur\//' | tr '\n' ' ' | xargs --no-run-if-empty yay -S --noconfirm
  sudo updatedb
  notify-send \
    --urgency=normal \
    --icon=software-update-available \
    "AUR Packages Installed" \
    "${pkg_names} AUR packages installed" 2>/dev/null || true
  zenith-done
fi
