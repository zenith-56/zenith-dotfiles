#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Package Remove
# =============================================================================
# Interactive package removal using fzf and yay

fzf_args=(
  --style minimal
  --multi
  --preview 'yay -Qi {1}'
  --preview-label-pos='bottom'
  --preview-window 'right:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:red,marker:red'
)

pkg_names=$(yay -Qqe | fzf "${fzf_args[@]}")

if [[ -n "$pkg_names" ]]; then
  echo "$pkg_names" | tr '\n' ' ' | xargs --no-run-if-empty yay -Rns --noconfirm
  notify-send \
    --urgency=normal \
    --icon=software-update-available \
    "Packages Removed" \
    "Selected packages removed" 2>/dev/null || true
  zenith-done
fi
