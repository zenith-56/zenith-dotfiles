#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Get Current Theme
# =============================================================================

DARKMAN_CFG="$HOME/.config/darkman.cfg"

if [ -f "$DARKMAN_CFG" ]; then
    theme=$(cat "$DARKMAN_CFG")
    if [ -z "$theme" ]; then
        echo "light"
    else
        echo "$theme"
    fi
elif pgrep -x darkman &>/dev/null; then
    echo "dark"
else
    echo "light"
fi