#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Restart Dunst
# =============================================================================

set -euo pipefail

if ! command -v dunst &>/dev/null; then
    echo "dunst not found"
    exit 1
fi

pkill dunst 2>/dev/null || true
sleep 0.2
dunst &>/dev/null &
echo "Dunst restarted"
