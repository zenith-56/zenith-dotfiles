#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Launch/Connect to VM
# =============================================================================

set -e

VM_CONFIG_DIR="$HOME/.config/zenith-vm/vms"

usage() {
  cat <<EOF
Usage: zenith-vm-launch [vm-name]

Launches a VM and opens the web console.

Options:
  --no-console    Don't open the web console
  -h, --help      Show this help
EOF
}

VM_NAME="${1:-}"
NO_CONSOLE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --no-console) NO_CONSOLE=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *)
      if [ -z "$VM_NAME" ]; then
        VM_NAME="$1"
      else
        echo "Unknown option: $1"
        usage
        exit 1
      fi
      shift
      ;;
  esac
done

# Interactive selection with gum
if [ -z "$VM_NAME" ]; then
  if command -v gum &>/dev/null; then
    VM_NAME=$(gum choose $(ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json) --header "Select VM to launch")
  else
    echo "Available VMs:"
    ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json
    echo ""
    read -rp "Enter VM name: " VM_NAME
  fi
  [ -z "$VM_NAME" ] && { echo "No VM selected"; exit 1; }
fi

CONFIG="$VM_CONFIG_DIR/${VM_NAME}.json"
if [ ! -f "$CONFIG" ]; then
  echo "Error: VM '$VM_NAME' not found"
  exit 1
fi

# Read config
get_json() { python3 -c "import json; d=json.load(open('$CONFIG')); print(d.get('$1',''))" 2>/dev/null; }

ENGINE=$(get_json "engine")
COMPOSE_FILE=$(get_json "compose_file")
WEB_PORT=$(get_json "web_port")

if [ "$ENGINE" = "docker" ]; then
  if ! command -v docker &>/dev/null; then
    echo "Error: docker is not installed"
    exit 1
  fi

  # Check if already running
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${VM_NAME}$"; then
    echo "VM '$VM_NAME' is already running"
  else
    echo "Starting VM '$VM_NAME'..."
    if [ -n "$COMPOSE_FILE" ] && [ -f "$COMPOSE_FILE" ]; then
      docker compose -f "$COMPOSE_FILE" up -d
    else
      echo "Error: compose file not found: $COMPOSE_FILE"
      exit 1
    fi
    echo "VM '$VM_NAME' started"
  fi

  # Open web console
  if [ "$NO_CONSOLE" = false ]; then
    echo "Opening web console at http://localhost:$WEB_PORT"
    xdg-open "http://localhost:$WEB_PORT" 2>/dev/null || true
  fi

elif [ "$ENGINE" = "qemu" ]; then
  if ! command -v virsh &>/dev/null; then
    echo "Error: libvirt/virsh is not installed"
    exit 1
  fi

  # Start via virsh
  if virsh domstate "$VM_NAME" 2>/dev/null | grep -q "running"; then
    echo "VM '$VM_NAME' is already running"
  else
    echo "Starting VM '$VM_NAME'..."
    virsh start "$VM_NAME"
    echo "VM '$VM_NAME' started"
  fi

  # Open virt-manager
  if [ "$NO_CONSOLE" = false ]; then
    virt-manager --show-domain-console="$VM_NAME" 2>/dev/null &
  fi
else
  echo "Error: Unknown engine: $ENGINE"
  exit 1
fi

# Update status in config
python3 -c "
import json
with open('$CONFIG', 'r') as f:
    d = json.load(f)
d['status'] = 'running'
with open('$CONFIG', 'w') as f:
    json.dump(d, f, indent=2)
" 2>/dev/null || true
