#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Keyboard Layout Switcher
# =============================================================================

case "$1" in
    us)     hyprctl keyword xkb_layout "us" ;;
    es)     hyprctl keyword xkb_layout "es" ;;
    toggle)
        current=$(hyprctl keyword xkb_layout -j | grep -o '"[^"]*"' | head -1 | tr -d '"')
        [ "$current" = "us" ] && hyprctl keyword xkb_layout "es" || hyprctl keyword xkb_layout "us"
        ;;
    *)      echo "Usage: $0 {us|es|toggle}" ;;
esac
