#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Keyboard Layout Switcher
# =============================================================================

set -euo pipefail

if ! command -v hyprctl &>/dev/null; then
    echo "hyprctl not found"
    exit 1
fi

if ! command -v jq &>/dev/null; then
    echo "jq not found"
    exit 1
fi

case "$1" in
    us)     hyprctl keyword xkb_layout "us" ;;
    es)     hyprctl keyword xkb_layout "es" ;;
    toggle)
        current=$(hyprctl keyword xkb_layout -j 2>/dev/null | jq -r '.[0].str // ""' 2>/dev/null || echo "")
        if [ "$current" = "us" ]; then
            hyprctl keyword xkb_layout "es"
        else
            hyprctl keyword xkb_layout "us"
        fi
        ;;
    *)      echo "Usage: $0 {us|es|toggle}"; exit 1 ;;
esac
