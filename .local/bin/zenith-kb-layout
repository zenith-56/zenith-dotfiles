#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Keyboard Layout Switcher
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

NIRI_INPUT="$HOME/.config/niri/input.kdl"

if ! command -v niri &>/dev/null; then
    echo "niri not found" >&2
    exit 1
fi

if [[ ! -f "$NIRI_INPUT" ]]; then
    echo "niri input.kdl not found" >&2
    exit 1
fi

kb_set() {
    local layout="$1"
    sed -i "s/layout \"[a-z]*\"/layout \"$layout\"/" "$NIRI_INPUT"
    niri msg action reload-config 2>/dev/null || true
}

kb_get_layouts() {
    grep -oP 'layout "\K[a-z]+' "$NIRI_INPUT" 2>/dev/null || echo "us"
}

kb_get() {
    kb_get_layouts | head -1
}

kb_toggle() {
    local layouts
    mapfile -t layouts < <(kb_get_layouts)
    local current
    current=$(kb_get)

    if (( ${#layouts[@]} < 2 )); then
        echo "Only one layout configured ($current), cannot toggle" >&2
        exit 1
    fi

    local next=""
    for (( i=0; i<${#layouts[@]}; i++ )); do
        if [[ "${layouts[$i]}" == "$current" ]]; then
            next="${layouts[$(( (i + 1) % ${#layouts[@]} ))]}"
            break
        fi
    done

    if [[ -z "$next" ]]; then
        next="${layouts[0]}"
    fi

    kb_set "$next"
}

case "${1:-}" in
    us)     kb_set "us" ;;
    es)     kb_set "es" ;;
    toggle) kb_toggle ;;
    get)    kb_get ;;
    *)      echo "Usage: $0 {us|es|toggle|get}"; exit 1 ;;
esac
