#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Network Info
# =============================================================================
# Usage:
#   zenith network status
#   zenith network ssid
# =============================================================================
set -euo pipefail

network_status() {
    if command -v impalactl &>/dev/null; then
        if impalactl gateway status 2>/dev/null | grep -qi "connected"; then
            echo "connected"
            return
        fi
    fi

    if command -v nmcli &>/dev/null; then
        if nmcli -t -f GENERAL.STATE dev show 2>/dev/null | grep -qi "connected"; then
            echo "connected"
            return
        fi
    fi

    if command -v iwgetid &>/dev/null; then
        if iwgetid -r 2>/dev/null | grep -q .; then
            echo "connected"
            return
        fi
    fi

    if command -v iwdctl &>/dev/null; then
        if iwdctl station list 2>/dev/null | grep -qi "connected"; then
            echo "connected"
            return
        fi
    fi

    echo "disconnected"
}

network_ssid() {
    if command -v impalactl &>/dev/null; then
        local ssid
        ssid=$(impalactl gateway status 2>/dev/null | grep "SSID" | awk '{print $2}' || true)
        if [[ -n "$ssid" ]]; then
            echo "$ssid"
            return
        fi
    fi

    if command -v iwgetid &>/dev/null; then
        local ssid
        ssid=$(iwgetid -r 2>/dev/null || true)
        if [[ -n "$ssid" ]]; then
            echo "$ssid"
            return
        fi
    fi

    if command -v nmcli &>/dev/null; then
        local ssid
        ssid=$(nmcli -t -f active,ssid dev wifi 2>/dev/null | grep "^yes" | cut -d: -f2 || true)
        if [[ -n "$ssid" ]]; then
            echo "$ssid"
            return
        fi
    fi

    echo ""
}

show_help() {
    cat << EOF
Network info

USAGE:
    zenith network <command>

COMMANDS:
    status          Check network connection status
    ssid            Get current WiFi SSID

EXAMPLES:
    zenith network status
    zenith network ssid

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    case "$1" in
        status)  network_status ;;
        ssid)    network_ssid ;;
        --help|-h|help) show_help ;;
        *)
            echo "Unknown command: $1" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
