#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Power Manager
# =============================================================================
# Usage:
#   zenith power off
#   zenith power reboot
#   zenith power lock
#   zenith power logout
#   zenith power profile [list|get|balanced|power-saver|performance|cycle]
# =============================================================================
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/zenith-lib.sh"

power_off() {
    zen_check_deps systemctl
    exec systemctl poweroff
}

power_reboot() {
    zen_check_deps systemctl
    exec systemctl reboot
}

power_lock() {
    zen_check_deps hyprlock
    exec hyprlock
}

power_logout() {
    zen_check_deps niri
    exec niri msg action quit
}

power_profile() {
    zen_check_deps powerprofilesctl

    get_profile() {
        powerprofilesctl get 2>/dev/null || powerprofilesctl list | grep -E '^\*' | awk '{print $2}' | tr -d ':'
    }

    case "${1:-}" in
        list)
            powerprofilesctl list
            ;;
        get)
            get_profile
            ;;
        balanced)
            powerprofilesctl set balanced
            ;;
        power-saver)
            powerprofilesctl set power-saver
            ;;
        performance)
            powerprofilesctl set performance
            ;;
        cycle)
            local profile
            profile=$(get_profile)
            case "$profile" in
                balanced)    powerprofilesctl set power-saver; notify-send "Power: Saver" 2>/dev/null || true ;;
                power-saver) powerprofilesctl set performance; notify-send "Power: Performance" 2>/dev/null || true ;;
                performance) powerprofilesctl set balanced; notify-send "Power: Balanced" 2>/dev/null || true ;;
                *)           powerprofilesctl set balanced ;;
            esac
            ;;
        *)
            echo "Usage: zenith power profile {list|get|balanced|power-saver|performance|cycle}"
            exit 1
            ;;
    esac
}

show_help() {
    cat << EOF
Power manager

USAGE:
    zenith power <command> [args]

COMMANDS:
    off                 Power off the system
    reboot              Reboot the system
    lock                Lock the screen
    logout              Logout of current session
    profile <action>    Power profile management

PROFILE ACTIONS:
    list                List available profiles
    get                 Get current profile
    balanced            Set balanced profile
    power-saver         Set power saver profile
    performance         Set performance profile
    cycle               Cycle through profiles

EXAMPLES:
    zenith power off
    zenith power reboot
    zenith power lock
    zenith power logout
    zenith power profile get
    zenith power profile cycle

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    case "$1" in
        off)        power_off ;;
        reboot)     power_reboot ;;
        lock)       power_lock ;;
        logout)     power_logout ;;
        profile)    power_profile "${2:-}" ;;
        --help|-h|help) show_help ;;
        *)
            echo "Unknown command: $1" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
