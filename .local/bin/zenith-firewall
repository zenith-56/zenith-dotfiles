#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Firewall Manager
# =============================================================================
# Manage ufw firewall: toggle, enable custom rules, status
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

zen_check_deps ufw

get_status() {
    if [ -f /etc/ufw/ufw.conf ]; then
        grep -q '^ENABLED=yes' /etc/ufw/ufw.conf 2>/dev/null && echo "active" || echo "inactive"
    else
        sudo ufw status verbose 2>/dev/null | head -1 | awk '{print $2}' || echo "unknown"
    fi
}

case "${1:-status}" in
    status)
        get_status
        ;;
    enable)
        sudo ufw enable
        zen_notify "Firewall" "Firewall enabled" "network-firewall"
        ;;
    disable)
        sudo ufw disable
        zen_notify "Firewall" "Firewall disabled" "network-firewall"
        ;;
    toggle)
        current=$(get_status)
        if [ "$current" = "active" ]; then
            sudo ufw disable
            zen_notify "Firewall" "Firewall disabled" "network-firewall"
        else
            sudo ufw enable
            zen_notify "Firewall" "Firewall enabled" "network-firewall"
        fi
        ;;
    rule)
        if [ -z "${2:-}" ]; then
            echo "Error: rule required"
            exit 1
        fi
        sudo ufw "$2"
        zen_notify "Firewall" "Rule applied: $2" "network-firewall"
        ;;
    *)
        echo "Usage: $0 {status|enable|disable|toggle|rule <rule>}"
        exit 1
        ;;
esac
