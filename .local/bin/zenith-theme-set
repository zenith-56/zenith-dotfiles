#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Set Theme (dark/light)
# =============================================================================

case "$1" in
    dark|light)
        echo "$1" > "$HOME/.config/darkman.cfg"
        darkman set "$1" 2>/dev/null || true
        ;;
    *)
        echo "Usage: $0 {dark|light}"
        exit 1
        ;;
esac
