#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Restart All Services
# =============================================================================

set -euo pipefail

BIN="$HOME/.local/bin"

if ! command -v waybar &>/dev/null; then
    echo "waybar not found"
    exit 1
fi

if ! command -v dunst &>/dev/null; then
    echo "dunst not found"
    exit 1
fi

if ! command -v swayosd-server &>/dev/null; then
    echo "swayosd-server not found"
    exit 1
fi

pkill waybar 2>/dev/null || true
pkill dunst 2>/dev/null || true
pkill swayosd-server 2>/dev/null || true

sleep 0.3

waybar &>/dev/null &
dunst &>/dev/null &
swayosd-server &>/dev/null &
"$BIN/zenith-reload-kitty"

echo "All services restarted"
