#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Brightness Control
# =============================================================================
# Usage:
#   zenith brightness get
#   zenith brightness set <value>
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

brightness_get() {
    if ! command -v brightnessctl &>/dev/null; then
        echo "0"
        exit 1
    fi
    brightnessctl get 2>/dev/null | sed 's/.*(\([0-9]*\)%).*/\1/' || echo "0"
}

brightness_set() {
    local value="${1:-}"
    if [[ -z "$value" ]]; then
        echo "Usage: zenith brightness set <value>"
        exit 1
    fi
    if ! command -v brightnessctl &>/dev/null; then
        exit 1
    fi
    brightnessctl set "${value}%" 2>/dev/null || exit 1
}

show_help() {
    cat << EOF
Brightness control

USAGE:
    zenith brightness <command> [args]

COMMANDS:
    get             Get current brightness percentage
    set <value>     Set brightness (0-100)

EXAMPLES:
    zenith brightness get
    zenith brightness set 50

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    case "$1" in
        get)    brightness_get ;;
        set)    brightness_set "${2:-}" ;;
        --help|-h|help) show_help ;;
        *)
            echo "Unknown command: $1" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
