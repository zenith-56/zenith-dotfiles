#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Media Controls
# =============================================================================

case "$1" in
    play)   playerctl play ;;
    pause)  playerctl pause ;;
    next)   playerctl next ;;
    prev)   playerctl previous ;;
    stop)   playerctl stop ;;
    *)      echo "Usage: $0 {play|pause|next|prev|stop}" ;;
esac
