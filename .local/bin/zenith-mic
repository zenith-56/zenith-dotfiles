#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Mic Mute/Unmute
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

zen_check_deps wpctl

wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle || {
    echo "Failed to toggle mic" >&2
    exit 1
}

muted=$(wpctl get-mute @DEFAULT_AUDIO_SOURCE@ 2>/dev/null) || {
    echo "Failed to get mic status" >&2
    exit 1
}

if [[ "$muted" == *"Muted"* ]]; then
    zen_notify "Mic" "Muted"
else
    zen_notify "Mic" "Unmuted"
fi
