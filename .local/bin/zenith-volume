#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Volume Control
# =============================================================================
# Usage:
#   zenith volume get
#   zenith volume set <value>
# =============================================================================
set -euo pipefail

volume_get() {
    if ! command -v pamixer &>/dev/null; then
        echo "0"
        exit 1
    fi
    pamixer --get-volume 2>/dev/null || echo "0"
}

volume_set() {
    local value="${1:-}"
    if [[ -z "$value" ]]; then
        echo "Usage: zenith volume set <value>"
        exit 1
    fi
    if ! command -v pamixer &>/dev/null; then
        exit 1
    fi
    pamixer --set-volume "$value" 2>/dev/null || exit 1
}

show_help() {
    cat << EOF
Volume control

USAGE:
    zenith volume <command> [args]

COMMANDS:
    get             Get current volume percentage
    set <value>     Set volume (0-100)

EXAMPLES:
    zenith volume get
    zenith volume set 50

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    case "$1" in
        get)    volume_get ;;
        set)    volume_set "${2:-}" ;;
        --help|-h|help) show_help ;;
        *)
            echo "Unknown command: $1" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
