#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Flatpak Package Install
# =============================================================================
# Interactive Flatpak package installation using fzf and flatpak

set -euo pipefail

if ! command -v flatpak &>/dev/null; then
    echo "flatpak not found"
    exit 1
fi

if ! command -v fzf &>/dev/null; then
    echo "fzf not found"
    exit 1
fi

fzf_args=(
  --style minimal
  --multi
  --preview 'flatpak remote-info flathub {1}'
  --preview-window 'right:75%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:green,marker:green'
)

pkg_names=$(flatpak remote-ls flathub --app --columns=application | fzf "${fzf_args[@]}") || exit 0

if [[ -n "$pkg_names" ]]; then
  echo "$pkg_names" | tr '\n' ' ' | xargs --no-run-if-empty flatpak install flathub -y
  notify-send \
    --urgency=normal \
    --icon=software-update-available \
    "Flatpak Packages Installed" \
    "${pkg_names} flatpak packages installed" 2>/dev/null || true
  zenith-done
fi
