#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - List All VMs
# =============================================================================

set -e

VM_CONFIG_DIR="$HOME/.config/zenith-vm/vms"

usage() {
  cat <<EOF
Usage: zenith-vm-list [options]

Lists all VMs.

Options:
  --json       Output in JSON format
  --running    Show only running VMs
  -h, --help   Show this help
EOF
}

JSON_OUTPUT=false
RUNNING_ONLY=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --json) JSON_OUTPUT=true; shift ;;
    --running) RUNNING_ONLY=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 1 ;;
  esac
done

# Check if any VMs exist
if ! ls "$VM_CONFIG_DIR"/*.json &>/dev/null; then
  if [ "$JSON_OUTPUT" = true ]; then
    echo "[]"
  else
    echo "No VMs configured. Run 'zenith-vm install' to create one."
  fi
  exit 0
fi

if [ "$JSON_OUTPUT" = true ]; then
  python3 -c "
import json, glob, os

vms = []
for f in sorted(glob.glob('$VM_CONFIG_DIR/*.json')):
    with open(f) as fh:
        d = json.load(fh)
    # Check actual status
    status = d.get('status', 'unknown')
    if d.get('engine') == 'docker':
        import subprocess
        try:
            r = subprocess.run(['docker', 'ps', '--format', '{{.Names}}'], capture_output=True, text=True)
            if d['name'] in r.stdout.split():
                status = 'running'
            else:
                status = 'stopped'
        except:
            pass
    d['status'] = status
    vms.append(d)

$([ "$RUNNING_ONLY" = true ] && echo "vms = [v for v in vms if v['status'] == 'running']")
print(json.dumps(vms, indent=2))
"
else
  # Table output
  printf "%-20s %-12s %-10s %-8s %-8s %-8s\n" "NAME" "OS" "ENGINE" "RAM" "CPUS" "STATUS"
  printf "%-20s %-12s %-10s %-8s %-8s %-8s\n" "----" "--" "------" "---" "----" "------"

  for config in "$VM_CONFIG_DIR"/*.json; do
    get_json() { python3 -c "import json; d=json.load(open('$config')); print(d.get('$1',''))" 2>/dev/null; }

    NAME=$(get_json "name")
    OS_TYPE=$(get_json "os_type")
    OS_VERSION=$(get_json "os_version")
    ENGINE=$(get_json "engine")
    RAM=$(get_json "ram")
    CPUS=$(get_json "cpus")
    STATUS=$(get_json "status")

    # Check actual runtime status
    if [ "$ENGINE" = "docker" ]; then
      if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${NAME}$"; then
        STATUS="running"
      else
        STATUS="stopped"
      fi
    elif [ "$ENGINE" = "qemu" ]; then
      if virsh domstate "$NAME" 2>/dev/null | grep -q "running"; then
        STATUS="running"
      else
        STATUS="stopped"
      fi
    fi

    if [ "$RUNNING_ONLY" = true ] && [ "$STATUS" != "running" ]; then
      continue
    fi

    printf "%-20s %-12s %-10s %-8s %-8s %-8s\n" "$NAME" "$OS_TYPE $OS_VERSION" "$ENGINE" "$RAM" "$CPUS" "$STATUS"
  done
fi
