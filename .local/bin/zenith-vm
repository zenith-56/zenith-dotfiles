#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - VM Manager Main CLI Entry Point
# =============================================================================

BIN="$HOME/.local/bin"

usage() {
  cat <<'EOF'
zenith-vm - Virtual Machine Manager

Usage: zenith-vm <command> [options]

Commands:
  install          Create and install a new VM
  launch           Start and connect to a VM
  stop             Stop a running VM
  remove           Remove a VM and its data
  status           Show VM status
  list             List all VMs
  snapshot         Manage snapshots
  console          Open VNC/web console
  settings         Edit VM configuration

Run 'zenith-vm <command> --help' for more information.
EOF
}

case "${1:-}" in
  install)
    exec "$BIN/zenith-vm-install" "${@:2}"
    ;;
  launch)
    exec "$BIN/zenith-vm-launch" "${@:2}"
    ;;
  stop)
    exec "$BIN/zenith-vm-stop" "${@:2}"
    ;;
  remove)
    exec "$BIN/zenith-vm-remove" "${@:2}"
    ;;
  status)
    exec "$BIN/zenith-vm-status" "${@:2}"
    ;;
  list)
    exec "$BIN/zenith-vm-list" "${@:2}"
    ;;
  snapshot)
    case "${2:-}" in
      create)
        exec "$BIN/zenith-vm-snapshot-create" "${@:3}"
        ;;
      restore)
        exec "$BIN/zenith-vm-snapshot-restore" "${@:3}"
        ;;
      list)
        exec "$BIN/zenith-vm-snapshot-list" "${@:3}"
        ;;
      *)
        echo "Usage: zenith-vm snapshot {create|restore|list} [vm-name]"
        exit 1
        ;;
    esac
    ;;
  console)
    exec "$BIN/zenith-vm-console" "${@:2}"
    ;;
  settings)
    exec "$BIN/zenith-vm-settings" "${@:2}"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    if [ -n "${1:-}" ]; then
      echo "Unknown command: $1"
      echo ""
    fi
    usage
    exit 1
    ;;
esac
