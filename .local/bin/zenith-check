#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - System Health Check
# =============================================================================
# Validates configs, services, packages, and system state
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

PASSED=0
FAILED=0
WARNED=0

pass() { echo -e "${ZEN_GREEN}[✓]${ZEN_RESET} $1"; PASSED=$((PASSED + 1)); }
fail() { echo -e "${ZEN_RED}[✗]${ZEN_RESET} $1"; FAILED=$((FAILED + 1)); }
warn() { echo -e "${ZEN_YELLOW}[!]${ZEN_RESET} $1"; WARNED=$((WARNED + 1)); }
info() { echo -e "${ZEN_CYAN}[i]${ZEN_RESET} $1"; }

# ── Config Validation ─────────────────────────────────────────────────────────
check_configs() {
    info "Checking configs..."

    if [ -f "$HOME/.config/waybar/config" ]; then
        if jq empty "$HOME/.config/waybar/config" 2>/dev/null; then
            pass "Waybar config JSON valid"
        else
            fail "Waybar config JSON invalid"
        fi
    else
        warn "Waybar config not found"
    fi

    for kdl_file in "$HOME/.config/niri/"*.kdl; do
        if [ -f "$kdl_file" ]; then
            local open_braces close_braces
            open_braces=$(grep -o '{' "$kdl_file" 2>/dev/null | wc -l)
            close_braces=$(grep -o '}' "$kdl_file" 2>/dev/null | wc -l)
            if [ "$open_braces" -eq "$close_braces" ]; then
                pass "Niri config valid: $(basename "$kdl_file")"
            else
                fail "Niri config invalid: $(basename "$kdl_file") (unbalanced braces)"
            fi
        fi
    done

    if [ -f "$HOME/.config/kitty/kitty.conf" ]; then
        if grep -qE "^[a-z_]+" "$HOME/.config/kitty/kitty.conf" 2>/dev/null; then
            pass "Kitty config valid"
        else
            warn "Kitty config may be empty or invalid"
        fi
    else
        warn "Kitty config not found"
    fi

    if [ -f "$HOME/.config/hypr/hyprlock.conf" ]; then
        pass "Hyprlock config exists"
    else
        warn "Hyprlock config not found"
    fi

    if [ -f "$HOME/.config/matugen/config.toml" ]; then
        pass "Matugen config exists"
    else
        warn "Matugen config not found"
    fi
}

# ── Service Status ─────────────────────────────────────────────────────────────
check_services() {
    info "Checking services..."

    local services=("waybar" "dunst" "swayosd-server" "darkman")
    for svc in "${services[@]}"; do
        if pgrep -x "$svc" &>/dev/null; then
            pass "$svc is running"
        else
            warn "$svc is not running"
        fi
    done
}

# ── Package Check ──────────────────────────────────────────────────────────────
check_packages() {
    info "Checking packages..."

    local packages=(
        "waybar" "dunst" "kitty" "niri" "rofi" "btop" "yazi"
        "hyprlock" "hypridle" "swayosd" "darkman" "matugen"
        "fzf" "gum" "fish" "jq" "ffmpeg" "imagemagick"
    )

    local missing=()
    for pkg in "${packages[@]}"; do
        if ! command -v "$pkg" &>/dev/null; then
            missing+=("$pkg")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        pass "All packages installed"
    else
        warn "Missing packages: ${missing[*]}"
    fi
}

# ── Bin Scripts Check ─────────────────────────────────────────────────────────
check_bin_scripts() {
    info "Checking bin scripts..."

    local bin_dir="$HOME/.local/bin"
    local missing_perms=()
    local missing_scripts=()

    if [ -d "$bin_dir" ]; then
        for script in "$bin_dir"/zenith-*; do
            if [ -f "$script" ]; then
                if [ ! -x "$script" ]; then
                    missing_perms+=("$(basename "$script")")
                fi
                if ! head -1 "$script" | grep -q '#!/usr/bin/env bash'; then
                    warn "Missing portable shebang: $(basename "$script")"
                fi
            fi
        done

        local expected_scripts=(
            "zenith" "zenith-lib.sh"
            "zenith-theme" "zenith-pkg" "zenith-restart" "zenith-power"
            "zenith-screenshot" "zenith-screen-recorder" "zenith-brightness"
            "zenith-volume" "zenith-battery" "zenith-network" "zenith-osd"
            "zenith-mic" "zenith-music-show" "zenith-kb-layout"
            "zenith-firewall" "zenith-dns" "zenith-check" "zenith-webapp"
        )

        for script in "${expected_scripts[@]}"; do
            if [ ! -f "$bin_dir/$script" ]; then
                missing_scripts+=("$script")
            fi
        done

        if [ ${#missing_perms[@]} -eq 0 ]; then
            pass "All bin scripts have correct permissions"
        else
            warn "Scripts missing execute permission: ${missing_perms[*]}"
        fi

        if [ ${#missing_scripts[@]} -eq 0 ]; then
            pass "All expected bin scripts present"
        else
            fail "Missing bin scripts: ${missing_scripts[*]}"
        fi
    else
        fail "Bin directory not found: $bin_dir"
    fi
}

# ── Rofi Scripts Check ────────────────────────────────────────────────────────
check_rofi_scripts() {
    info "Checking rofi scripts..."

    local rofi_dir="$HOME/.config/rofi/scripts"
    if [ -d "$rofi_dir" ]; then
        local missing_perms=()
        for script in "$rofi_dir"/*.sh; do
            if [ -f "$script" ] && [ ! -x "$script" ]; then
                missing_perms+=("$(basename "$script")")
            fi
        done

        if [ ${#missing_perms[@]} -eq 0 ]; then
            pass "All rofi scripts have correct permissions"
        else
            warn "Rofi scripts missing execute permission: ${missing_perms[*]}"
        fi
    else
        warn "Rofi scripts directory not found"
    fi
}

# ── Darkman Check ──────────────────────────────────────────────────────────────
check_darkman() {
    info "Checking darkman..."

    if command -v darkman &>/dev/null; then
        pass "Darkman is installed"
    else
        warn "Darkman is not installed"
        return
    fi

    if [ -f "$HOME/.config/darkman.cfg" ]; then
        pass "Darkman config exists"
    else
        warn "Darkman config not found"
    fi

    if [ -d "$HOME/.local/share/dark-mode.d" ] && [ -d "$HOME/.local/share/light-mode.d" ]; then
        local dark_count light_count
        dark_count=$(find "$HOME/.local/share/dark-mode.d" -name "*.sh" 2>/dev/null | wc -l)
        light_count=$(find "$HOME/.local/share/light-mode.d" -name "*.sh" 2>/dev/null | wc -l)
        pass "Darkman scripts: $dark_count dark, $light_count light"
    else
        warn "Darkman script directories not found"
    fi
}

# ── Disk Space Check ──────────────────────────────────────────────────────────
check_disk() {
    info "Checking disk space..."

    local usage
    usage=$(df -h / | awk 'NR==2 {print $5}' | tr -d '%')
    if [ "$usage" -lt 80 ]; then
        pass "Disk usage: ${usage}%"
    elif [ "$usage" -lt 90 ]; then
        warn "Disk usage: ${usage}% (getting high)"
    else
        fail "Disk usage: ${usage}% (critical)"
    fi
}

# ── Memory Check ──────────────────────────────────────────────────────────────
check_memory() {
    info "Checking memory..."

    if [ -f /proc/meminfo ]; then
        local total available usage
        total=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
        available=$(awk '/MemAvailable/ {print $2}' /proc/meminfo)
        usage=$(( (total - available) * 100 / total ))

        if [ "$usage" -lt 80 ]; then
            pass "Memory usage: ${usage}%"
        elif [ "$usage" -lt 90 ]; then
            warn "Memory usage: ${usage}% (getting high)"
        else
            fail "Memory usage: ${usage}% (critical)"
        fi
    else
        warn "Cannot read memory info"
    fi
}

# ── Summary ────────────────────────────────────────────────────────────────────
print_summary() {
    echo ""
    info "Summary: $PASSED passed, $FAILED failed, $WARNED warnings"
    echo ""

    if [ "$FAILED" -gt 0 ]; then
        exit 1
    fi
}

# ── Main ───────────────────────────────────────────────────────────────────────
main() {
    echo ""
    echo -e "${ZEN_CYAN}╔══════════════════════════════════════════╗${ZEN_RESET}"
    echo -e "${ZEN_CYAN}║${ZEN_RESET}   Zenith-Dotfiles Health Check       ${ZEN_CYAN}║${ZEN_RESET}"
    echo -e "${ZEN_CYAN}╚══════════════════════════════════════════╝${ZEN_RESET}"
    echo ""

    check_configs
    echo ""
    check_services
    echo ""
    check_packages
    echo ""
    check_bin_scripts
    echo ""
    check_rofi_scripts
    echo ""
    check_darkman
    echo ""
    check_disk
    echo ""
    check_memory

    print_summary
}

main "$@"
