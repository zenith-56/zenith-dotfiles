#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Done Prompt
# =============================================================================
# Description : Shows a "Press ENTER to close..." prompt.
#               Used at the end of TUI operations to keep the terminal open.
# =============================================================================

echo ""
echo -e "\033[0;32m✓\033[0m Done."
echo ""
read -rp "Press ENTER to close..."
