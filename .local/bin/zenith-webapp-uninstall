#!/usr/bin/env bash
# =============================================================================
# zenith-webapp-uninstall — Web app remover for Zenith-Dotfiles
# Lists installed web apps and lets user select multiple to remove
#
# Usage:
#   zenith-webapp-uninstall
# =============================================================================
set -e

APPS_DIR="$HOME/.local/share/applications"

# ── Find web apps ─────────────────────────────────────────────────────────────
mapfile -t webapps < <(
    grep -l 'Categories=WebApp;' "$APPS_DIR"/*.desktop 2>/dev/null | \
    while read -r f; do
        grep '^Name=' "$f" | head -1 | sed 's/^Name=//'
    done | sort
)

if (( ${#webapps[@]} == 0 )); then
    echo -e "\e[33mNo web apps installed.\e[0m"
    exit 0
fi

# ── Multi-select ──────────────────────────────────────────────────────────────
echo -e "\e[32m── Zenith-Dotfiles Web App Uninstaller ──\e[0m\n"
echo -e "\e[2mUse Space to select, Enter to confirm\e[0m\n"

selected=()
mapfile -t selected < <(
    gum choose --no-limit --header "Select web apps to uninstall:" "${webapps[@]}"
)

if (( ${#selected[@]} == 0 )); then
    echo -e "\e[33mNo apps selected.\e[0m"
    exit 0
fi

# ── Confirm ───────────────────────────────────────────────────────────────────
echo ""
echo -e "\e[31mThe following apps will be removed:\e[0m"
for app in "${selected[@]}"; do
    echo "  • $app"
done
echo ""

confirm=$(gum choose --header "Proceed?" "Yes" "No")
[[ "$confirm" != "Yes" ]] && exit 0

# ── Remove ────────────────────────────────────────────────────────────────────
for app in "${selected[@]}"; do
    SAFE_NAME="${app// /_}"
    SAFE_NAME="${SAFE_NAME//[^a-zA-Z0-9_.-]/}"
    DESKTOP_FILE="$APPS_DIR/$SAFE_NAME.desktop"

    if [[ -f "$DESKTOP_FILE" ]]; then
        # Extract icon path before removing
        ICON_PATH=$(grep '^Icon=' "$DESKTOP_FILE" | sed 's/^Icon=//' || true)

        rm -f "$DESKTOP_FILE"
        echo -e "\e[32m✓ Removed $app\e[0m"

        # Clean up icon if it's in our icon directory
        if [[ -n "$ICON_PATH" && "$ICON_PATH" == "$HOME/.local/share/applications/icons/"* ]]; then
            rm -f "$ICON_PATH"
            echo -e "\e[2m  Cleaned up icon\e[0m"
        fi
    else
        echo -e "\e[33m Desktop file not found for $app\e[0m"
    fi
done

# Update desktop database
update-desktop-database "$APPS_DIR" 2>/dev/null || true

echo -e "\n\e[32mDone. ${#selected[@]} app(s) removed.\e[0m"
