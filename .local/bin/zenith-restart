#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Restart Services
# =============================================================================
# Usage:
#   zenith restart waybar
#   zenith restart dunst
#   zenith restart swayosd
#   zenith restart kitty
#   zenith restart all
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/zenith-lib.sh"

restart_service() {
    local name="$1"
    local cmd="$2"

    zen_check_deps "$cmd"

    pkill "$cmd" 2>/dev/null || true
    sleep 0.5
    "$cmd" &>/dev/null &
    zen_notify "$name restarted" ""
}

reload_kitty() {
    local pids
    pids=$(pidof kitty 2>/dev/null) || true
    if [[ -n "$pids" ]]; then
        for pid in $pids; do
            kill -SIGUSR1 "$pid" 2>/dev/null || true
        done
    fi
}

show_help() {
    cat << EOF
Restart services

USAGE:
    zenith restart <service>

SERVICES:
    waybar      Restart waybar
    dunst       Restart dunst
    swayosd     Restart swayosd-server
    kitty       Reload kitty colors (SIGUSR1)
    all         Restart all services + reload kitty

EOF
}

main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    case "$1" in
        waybar)   restart_service "Waybar" "waybar" ;;
        dunst)    restart_service "Dunst" "dunst" ;;
        swayosd)  restart_service "SwayOSD" "swayosd-server" ;;
        kitty)    reload_kitty ;;
        all)
            local all_cmds=("waybar" "dunst" "swayosd-server")
            for svc in "${all_cmds[@]}"; do
                if command -v "$svc" &>/dev/null; then
                    pkill "$svc" 2>/dev/null || true
                fi
            done
            sleep 0.5
            for svc in "${all_cmds[@]}"; do
                if command -v "$svc" &>/dev/null; then
                    "$svc" &>/dev/null &
                fi
            done
            reload_kitty
            zen_notify "All services restarted" ""
            ;;
        --help|-h|help)
            show_help
            ;;
        *)
            echo "Unknown service: $1" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
