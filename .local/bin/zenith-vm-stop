#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Stop Running VM
# =============================================================================

set -e

VM_CONFIG_DIR="$HOME/.config/zenith-vm/vms"

usage() {
  cat <<EOF
Usage: zenith-vm-stop [vm-name]

Stops a running VM.

Options:
  --force    Force stop (kill)
  -h, --help Show this help
EOF
}

VM_NAME="${1:-}"
FORCE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --force) FORCE=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *)
      if [ -z "$VM_NAME" ]; then
        VM_NAME="$1"
      else
        echo "Unknown option: $1"
        usage
        exit 1
      fi
      shift
      ;;
  esac
done

# Interactive selection with gum
if [ -z "$VM_NAME" ]; then
  if command -v gum &>/dev/null; then
    VM_NAME=$(gum choose $(ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json) --header "Select VM to stop")
  else
    echo "Available VMs:"
    ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json
    echo ""
    read -rp "Enter VM name: " VM_NAME
  fi
  [ -z "$VM_NAME" ] && { echo "No VM selected"; exit 1; }
fi

CONFIG="$VM_CONFIG_DIR/${VM_NAME}.json"
if [ ! -f "$CONFIG" ]; then
  echo "Error: VM '$VM_NAME' not found"
  exit 1
fi

# Read config
get_json() { python3 -c "import json; d=json.load(open('$CONFIG')); print(d.get('$1',''))" 2>/dev/null; }

ENGINE=$(get_json "engine")

if [ "$ENGINE" = "docker" ]; then
  if [ "$FORCE" = true ]; then
    echo "Force stopping VM '$VM_NAME'..."
    docker kill "$VM_NAME" 2>/dev/null || true
  else
    echo "Stopping VM '$VM_NAME'..."
    docker stop "$VM_NAME" 2>/dev/null || true
  fi

elif [ "$ENGINE" = "qemu" ]; then
  if [ "$FORCE" = true ]; then
    echo "Force stopping VM '$VM_NAME'..."
    virsh destroy "$VM_NAME" 2>/dev/null || true
  else
    echo "Stopping VM '$VM_NAME'..."
    virsh shutdown "$VM_NAME" 2>/dev/null || true
  fi
else
  echo "Error: Unknown engine: $ENGINE"
  exit 1
fi

# Update status
python3 -c "
import json
with open('$CONFIG', 'r') as f:
    d = json.load(f)
d['status'] = 'stopped'
with open('$CONFIG', 'w') as f:
    json.dump(d, f, indent=2)
" 2>/dev/null || true

echo "VM '$VM_NAME' stopped"
