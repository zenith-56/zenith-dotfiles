#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Edit VM Configuration
# =============================================================================

set -e

VM_CONFIG_DIR="$HOME/.config/zenith-vm/vms"

usage() {
  cat <<EOF
Usage: zenith-vm-settings [vm-name]

Edit VM configuration interactively.

Options:
  --ram RAM      Set RAM allocation
  --cpus N       Set CPU cores
  --disk SIZE    Set disk size
  --web-port P   Set web console port
  --gpu BOOL     Enable/disable GPU passthrough (true/false)
  -h, --help     Show this help
EOF
}

VM_NAME="${1:-}"

shift 2>/dev/null || true

# Parse flags
NEW_RAM=""
NEW_CPUS=""
NEW_DISK=""
NEW_WEB_PORT=""
NEW_GPU=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --ram) NEW_RAM="$2"; shift 2 ;;
    --cpus) NEW_CPUS="$2"; shift 2 ;;
    --disk) NEW_DISK="$2"; shift 2 ;;
    --web-port) NEW_WEB_PORT="$2"; shift 2 ;;
    --gpu) NEW_GPU="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *)
      if [ -z "$VM_NAME" ]; then
        VM_NAME="$1"
      else
        echo "Unknown option: $1"
        usage
        exit 1
      fi
      shift
      ;;
  esac
done

# Interactive selection with gum
if [ -z "$VM_NAME" ]; then
  if command -v gum &>/dev/null; then
    VM_NAME=$(gum choose $(ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json) --header "Select VM to configure")
  else
    echo "Available VMs:"
    ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json
    echo ""
    read -rp "Enter VM name: " VM_NAME
  fi
  [ -z "$VM_NAME" ] && { echo "No VM selected"; exit 1; }
fi

CONFIG="$VM_CONFIG_DIR/${VM_NAME}.json"
if [ ! -f "$CONFIG" ]; then
  echo "Error: VM '$VM_NAME' not found"
  exit 1
fi

# Read current values
get_json() { python3 -c "import json; d=json.load(open('$CONFIG')); print(d.get('$1',''))" 2>/dev/null; }

CURRENT_RAM=$(get_json "ram")
CURRENT_CPUS=$(get_json "cpus")
CURRENT_DISK=$(get_json "disk")
CURRENT_WEB_PORT=$(get_json "web_port")
CURRENT_GPU=$(get_json "gpu_passthrough")

# Interactive mode with gum
if [ -z "$NEW_RAM" ] && [ -z "$NEW_CPUS" ] && [ -z "$NEW_DISK" ] && [ -z "$NEW_WEB_PORT" ] && [ -z "$NEW_GPU" ]; then
  if ! command -v gum &>/dev/null; then
    echo "Error: gum is required for interactive mode. Use flags instead."
    exit 1
  fi

  echo "Current configuration for '$VM_NAME':"
  echo "  RAM: $CURRENT_RAM"
  echo "  CPUs: $CURRENT_CPUS"
  echo "  Disk: $CURRENT_DISK"
  echo "  Web Port: $CURRENT_WEB_PORT"
  echo "  GPU Passthrough: $CURRENT_GPU"
  echo ""

  NEW_RAM=$(gum input --value "$CURRENT_RAM" --header "RAM allocation")
  NEW_CPUS=$(gum input --value "$CURRENT_CPUS" --header "CPU cores")
  NEW_DISK=$(gum input --value "$CURRENT_DISK" --header "Disk size")
  NEW_WEB_PORT=$(gum input --value "$CURRENT_WEB_PORT" --header "Web console port")
  NEW_GPU=$(gum choose "true" "false" --header "GPU passthrough" --default "$CURRENT_GPU")
fi

# Update config
python3 -c "
import json

with open('$CONFIG', 'r') as f:
    d = json.load(f)

$([ -n "$NEW_RAM" ] && echo "d['ram'] = '$NEW_RAM'")
$([ -n "$NEW_CPUS" ] && echo "d['cpus'] = int('$NEW_CPUS')")
$([ -n "$NEW_DISK" ] && echo "d['disk'] = '$NEW_DISK'")
$([ -n "$NEW_WEB_PORT" ] && echo "d['web_port'] = int('$NEW_WEB_PORT')")
$([ -n "$NEW_GPU" ] && echo "d['gpu_passthrough'] = $([ "$NEW_GPU" = "true" ] && echo "True" || echo "False")")

with open('$CONFIG', 'w') as f:
    json.dump(d, f, indent=2)
"

# Update compose file if Docker
COMPOSE_FILE=$(get_json "compose_file")
if [ -n "$COMPOSE_FILE" ] && [ -f "$COMPOSE_FILE" ]; then
  if [ -n "$NEW_RAM" ] || [ -n "$NEW_CPUS" ] || [ -n "$NEW_DISK" ] || [ -n "$NEW_WEB_PORT" ]; then
    # Regenerate compose file
    VM_DATA_DIR="$HOME/.local/share/zenith-vm"
    TEMPLATE_DIR="$HOME/.config/zenith-vm/templates"

    OS_TYPE=$(get_json "os_type")
    case "$OS_TYPE" in
      windows) TEMPLATE="$TEMPLATE_DIR/windows-compose.yml"
               export WIN_VERSION=$(get_json "os_version") ;;
      linux) TEMPLATE="$TEMPLATE_DIR/linux-compose.yml"
             export BOOT=$(get_json "os_version") ;;
    esac

    export VM_NAME RAM="${NEW_RAM:-$CURRENT_RAM}" CPUS="${NEW_CPUS:-$CURRENT_CPUS}" \
           DISK="${NEW_DISK:-$CURRENT_DISK}" WEB_PORT="${NEW_WEB_PORT:-$CURRENT_WEB_PORT}"

    envsubst < "$TEMPLATE" > "$COMPOSE_FILE"
    echo "Compose file updated"
  fi
fi

echo "Configuration updated for '$VM_NAME'"
