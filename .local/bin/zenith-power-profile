#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Power Profile Manager (DEPRECATED)
# =============================================================================
# This script is deprecated. Use 'zenith power profile' instead.
# Kept for backward compatibility with waybar modules.
# =============================================================================

set -euo pipefail

exec "$(dirname "${BASH_SOURCE[0]}")/zenith" power profile "$@"
