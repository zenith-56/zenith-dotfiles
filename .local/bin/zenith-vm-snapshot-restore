#!/usr/bin/env bash
# =============================================================================
# Zenith-Dotfiles - Restore VM Snapshot
# =============================================================================

set -e

VM_CONFIG_DIR="$HOME/.config/zenith-vm/vms"
SNAPSHOT_DIR="$HOME/.config/zenith-vm/snapshots"

usage() {
  cat <<EOF
Usage: zenith-vm-snapshot-restore [vm-name] [snapshot-name]

Restores a VM to a previous snapshot.

Options:
  -h, --help  Show this help
EOF
}

VM_NAME="${1:-}"
SNAPSHOT_NAME="${2:-}"

# Interactive selection with gum
if [ -z "$VM_NAME" ]; then
  if command -v gum &>/dev/null; then
    VM_NAME=$(gum choose $(ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json) --header "Select VM to restore")
  else
    echo "Available VMs:"
    ls "$VM_CONFIG_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json
    echo ""
    read -rp "Enter VM name: " VM_NAME
  fi
  [ -z "$VM_NAME" ] && { echo "No VM selected"; exit 1; }
fi

CONFIG="$VM_CONFIG_DIR/${VM_NAME}.json"
if [ ! -f "$CONFIG" ]; then
  echo "Error: VM '$VM_NAME' not found"
  exit 1
fi

# List snapshots if none specified
if [ -z "$SNAPSHOT_NAME" ]; then
  VM_SNAP_DIR="$SNAPSHOT_DIR/$VM_NAME"
  if [ ! -d "$VM_SNAP_DIR" ] || [ -z "$(ls "$VM_SNAP_DIR"/*.json 2>/dev/null)" ]; then
    echo "No snapshots found for VM '$VM_NAME'"
    exit 1
  fi

  if command -v gum &>/dev/null; then
    SNAPSHOT_NAME=$(gum choose $(ls "$VM_SNAP_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json) --header "Select snapshot to restore")
  else
    echo "Available snapshots:"
    ls "$VM_SNAP_DIR"/*.json 2>/dev/null | xargs -I{} basename {} .json
    echo ""
    read -rp "Enter snapshot name: " SNAPSHOT_NAME
  fi
  [ -z "$SNAPSHOT_NAME" ] && { echo "No snapshot selected"; exit 1; }
fi

# Remove .json extension if present
SNAPSHOT_NAME="${SNAPSHOT_NAME%.json}"

SNAP_CONFIG="$VM_SNAP_DIR/${SNAPSHOT_NAME}.json"
if [ ! -f "$SNAP_CONFIG" ]; then
  echo "Error: Snapshot '$SNAPSHOT_NAME' not found for VM '$VM_NAME'"
  exit 1
fi

# Confirm restore
if command -v gum &>/dev/null; then
  if ! gum confirm "Restore VM '$VM_NAME' to snapshot '$SNAPSHOT_NAME'? Current state will be lost." --affirmative "Restore" --negative "Cancel"; then
    echo "Cancelled"
    exit 0
  fi
else
  read -rp "Restore VM '$VM_NAME' to snapshot '$SNAPSHOT_NAME'? [y/N] " confirm
  [[ "$confirm" != [yY]* ]] && { echo "Cancelled"; exit 0; }
fi

# Read config
get_json() { python3 -c "import json; d=json.load(open('$CONFIG')); print(d.get('$1',''))" 2>/dev/null; }

ENGINE=$(get_json "engine")

# Stop VM first
"$HOME/.local/bin/zenith-vm-stop" "$VM_NAME" --force 2>/dev/null || true

# Restore snapshot
if [ "$ENGINE" = "docker" ]; then
  echo "Restoring VM '$VM_NAME' to snapshot '$SNAPSHOT_NAME'..."

  # Remove current container
  docker rm -f "$VM_NAME" 2>/dev/null || true

  # Get compose file
  COMPOSE_FILE=$(get_json "compose_file")
  if [ -n "$COMPOSE_FILE" ] && [ -f "$COMPOSE_FILE" ]; then
    # Recreate from compose
    docker compose -f "$COMPOSE_FILE" up -d
  else
    echo "Error: compose file not found"
    exit 1
  fi

elif [ "$ENGINE" = "qemu" ]; then
  echo "Restoring VM '$VM_NAME' to snapshot '$SNAPSHOT_NAME'..."
  virsh snapshot-revert "$VM_NAME" "$SNAPSHOT_NAME" 2>/dev/null || {
    echo "Error: Failed to restore snapshot"
    exit 1
  }
fi

echo "VM '$VM_NAME' restored to snapshot '$SNAPSHOT_NAME'"
