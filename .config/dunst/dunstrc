[global]
    monitor = 0
    follow = mouse
    frame_width = 0
    height = (0, 150)
    offset = (15, 15)
    origin = top-right

    corner_radius = 0
    padding = 15
    horizontal_padding = 15

    frame_color = "#16130b"
    separator_color = "#979080"

    font = JetBrainsMono Nerd Font 10
    alignment = left
    vertical_alignment = center

    format = "<span foreground='#dfc56d' weight='bold'>%s</span>\n%b"

[urgency_low]
    background = "#16130b"
    foreground = "#e9e2d4"
    frame_color = "#16130b"
    timeout = 3

[urgency_normal]
    background = "#16130b"
    foreground = "#e9e2d4"
    frame_color = "#16130b"
    timeout = 3

[urgency_critical]
    background = "#93000a"
    foreground = "#ffdad6"
    frame_color = "#ffb4ab"
    format = "<span foreground='#ffb4ab' weight='bold'>%s</span>\n%b"
    timeout = 0
