{
  "group/extras": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "extras",
      "transition-left-to-right": false
    },
    "modules": ["custom/menu", "tray"]
  },
  "group/brightness": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "brightness",
      "transition-left-to-right": false
    },
    "modules": ["backlight", "backlight/slider"]
  },
  "group/audio": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "audio",
      "transition-left-to-right": false
    },
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },
  "custom/cachy": {
    "format": "<span font-size='16pt'>≤░μΘ</span>",
    "tooltip": true,
    "tooltip-format": "Open Menu",
    "on-click": "$HOME/.config/rofi/scripts/launcher.sh"
  },
  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "ϊ╕Α",
      "2": "ϊ║Ν",
      "3": "ϊ╕Κ",
      "4": "ίδδ",
      "5": "ϊ║Φ",
      "6": "ίΖφ",
      "7": "ϊ╕Δ",
      "8": "ίΖτ",
      "9": "ϊ╣ζ",
      "10": "ίΞΒ",
      "default": "≤░Ε░",
      "active": "≤░Εψ"
    }
  },
  "custom/cpu_snake": {
    "exec": "$HOME/.config/waybar/scripts/braille-snake.sh",
    "format": "{}",
    "tooltip": false,
    "on-click": "kitty btop"
  },
  "clock": {
    "interval": 1,
    "format": "{:%H\n%M}",
    "format-alt": "{:%d\n%m\n%y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },
  "custom/menu": {
    "format": "<span size='16pt'>≤░ΖΔ</span>",
    "tooltip": false
  },
  "tray": {
    "spacing": 16,
    "reverse-direction": true,
    "icon-size": 16,
    "show-passive-items": false
  },
  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": false
      }
    ],
    "ignore": [
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },
  "network": {
    "format-icons": {
      "wifi": [
        "<span size='12pt'>≤░νψ</span>",
        "<span size='12pt'>≤░νθ</span>",
        "<span size='12pt'>≤░νλ</span>",
        "<span size='12pt'>≤░νξ</span>",
        "<span size='12pt'>≤░νρ</span>"
      ],
      "ethernet": "<span size='12pt'>≤░ΙΑ</span>",
      "disabled": "<span size='12pt'>≤░νφ</span>",
      "disconnected": "<span size='12pt'>≤░νσ</span>"
    },
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon}",
    "format-disabled": "{icon}",
    "interval": 5,
    "tooltip-format": "{essid}\t{gwaddr}",
    "on-click": "rfkill toggle wifi",
    "on-click-right": "kitty --title=impala impala",
    "tooltip": true,
    "max-length": 20
  },
  "bluetooth": {
    "interval": 5,
    "format-on": "<span size='14pt'>≤░Γψ</span>",
    "format-off": "<span size='14pt'>≤░Γ▓</span>",
    "format-disabled": "<span size='14pt'>≤░Γ▓</span>",
    "format-connected": "<span size='14pt'>≤░Γ▒</span>",
    "format-no-controller": "<span size='14pt'>≤░Γψ</span>",
    "tooltip": true,
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_address} | Battery: {device_battery_percentage}%",
    "on-click": "rfkill toggle bluetooth",
    "on-click-right": "kitty --title=bluetui bluetui"
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "<span size='14pt'>≤░Ξυ</span>",
    "format-source-muted": "<span size='14pt'>≤░Ξφ</span>",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip": false
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },
  "pulseaudio": {
    "interval": 1,
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>≤░Χ┐</span>",
      "<span size='14pt'>≤░ΨΑ</span>",
      "<span size='14pt'>≤░Χ╛</span>"
    ],
    "format-bluetooth": "<span size='14pt'>≤░ξ░</span>",
    "format-muted": "<span size='14pt'>≤░ζθ</span>",
    "on-click-right": "kitty --title=ncpamixer ncpamixer",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "reverse-scrolling": true,
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%\n{desc}",
    "ignored-sinks": ["Easy Effects Sink"]
  },
  "backlight/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical",
    "device": "intel_backlight"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": ["≤░Δγ", "≤░Δδ", "≤░Δε", "≤░Δζ", "≤░Δη", "≤░Δθ", "≤░Δι"],
    "reverse-scrolling": true,
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },
  "battery": {
    "interval": 60,
    "states": {
      "critical": 15
    },
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>ΎΚΕ</span>",
      "<span size='14pt'>ΎΚΔ</span>",
      "<span size='14pt'>ΎΚΓ</span>",
      "<span size='14pt'>ΎΚΒ</span>",
      "<span size='14pt'>ΎΚΑ</span>"
    ],
    "format-plugged": "<span size='14pt'>≤░γξ</span>",
    "format-critical": "<span size='14pt'>ΎΒ▒</span>",
    "tooltip": true,
    "tooltip-format": "{timeTo} , Now: {capacity}%",
    "tooltip-format-charging": "{timeTo}, Now: {capacity}%",
    "on-click": "notify-send 'ESTADO ENERG├ΞA' \"Nivel: $(cat /sys/class/power_supply/BAT0/capacity)% \nEstado: $(cat /sys/class/power_supply/BAT0/status)\" -u low"
  },
  "custom/powermenu": {
    "format": "<span size='13pt'>≤░Ρξ</span>",
    "on-click": "$HOME/.config/rofi/scripts/power-menu.sh",
    "tooltip": true,
    "tooltip-format": "Open Power Menu"
  }
}
