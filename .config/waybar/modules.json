{
  "group/extras": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "extras",
      "transition-left-to-right": false
    },
    "modules": ["custom/menu", "tray"]
  },
  "group/brightness": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "brightness",
      "transition-left-to-right": false
    },
    "modules": ["backlight", "backlight/slider"]
  },
  "group/audio": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "audio",
      "transition-left-to-right": false
    },
    "modules": ["pulseaudio", "pulseaudio/slider"]
  },
  "custom/cachy": {
    "format": "<span font-size='16pt'>¾░Żć</span>",
    "tooltip": true,
    "tooltip-format": "Open Menu",
    "on-click": "$HOME/.config/rofi/scripts/launcher.sh"
  },
  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "õĖĆ",
      "2": "õ║ī",
      "3": "õĖē",
      "4": "Õøø",
      "5": "õ║ö",
      "6": "ÕģŁ",
      "7": "õĖā",
      "8": "Õģ½",
      "9": "õ╣Ø",
      "10": "ÕŹü",
      "default": "¾░ä░",
      "active": "¾░ä»"
    }
  },
  "custom/cpu_snake": {
    "exec": "$HOME/.config/waybar/scripts/braille-snake.sh",
    "format": "{}",
    "tooltip": false,
    "on-click": "kitty btop"
  },
  "clock": {
    "interval": 1,
    "format": "{:%H\n%M}",
    "format-alt": "{:%d\n%m\n%y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },
  "custom/menu": {
    "format": "<span size='16pt'>¾░ģā</span>",
    "tooltip": false
  },
  "tray": {
    "spacing": 16,
    "reverse-direction": true,
    "icon-size": 16,
    "show-passive-items": false
  },
  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": false
      }
    ],
    "ignore": [
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },
  "network": {
    "format-icons": {
      "wifi": [
        "<span size='12pt'>¾░ż»</span>",
        "<span size='12pt'>¾░ż¤</span>",
        "<span size='12pt'>¾░żó</span>",
        "<span size='12pt'>¾░żź</span>",
        "<span size='12pt'>¾░ż©</span>"
      ],
      "ethernet": "<span size='12pt'>¾░łĆ</span>",
      "disabled": "<span size='12pt'>¾░żŁ</span>",
      "disconnected": "<span size='12pt'>¾░ż®</span>"
    },
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon}",
    "format-disabled": "{icon}",
    "interval": 5,
    "tooltip-format": "{essid}\t{gwaddr}",
    "on-click": "rfkill toggle wifi",
    "on-click-right": "kitty --title=impala impala",
    "tooltip": true,
    "max-length": 20
  },
  "bluetooth": {
    "interval": 5,
    "format-on": "<span size='14pt'>¾░é»</span>",
    "format-off": "<span size='14pt'>¾░é▓</span>",
    "format-disabled": "<span size='14pt'>¾░é▓</span>",
    "format-connected": "<span size='14pt'>¾░é▒</span>",
    "format-no-controller": "<span size='14pt'>¾░é»</span>",
    "tooltip": true,
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_address} | Battery: {device_battery_percentage}%",
    "on-click": "rfkill toggle bluetooth",
    "on-click-right": "kitty --title=bluetui bluetui"
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "<span size='14pt'>¾░Ź¼</span>",
    "format-source-muted": "<span size='14pt'>¾░ŹŁ</span>",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip": false
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },
  "pulseaudio": {
    "interval": 1,
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>¾░Ģ┐</span>",
      "<span size='14pt'>¾░¢Ć</span>",
      "<span size='14pt'>¾░ĢŠ</span>"
    ],
    "format-bluetooth": "<span size='14pt'>¾░ź░</span>",
    "format-muted": "<span size='14pt'>¾░Ø¤</span>",
    "on-click-right": "kitty --title=ncpamixer ncpamixer",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "reverse-scrolling": true,
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%\n{desc}",
    "ignored-sinks": ["Easy Effects Sink"]
  },
  "backlight/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },
  "backlight": {
    "format": "{icon}",
    "format-icons": ["¾░āÜ", "¾░āø", "¾░ā£", "¾░āØ", "¾░ā×", "¾░ā¤", "¾░āĀ"],
    "reverse-scrolling": true,
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },
  "battery": {
    "interval": 60,
    "states": {
      "critical": 15
    },
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>’ēä</span>",
      "<span size='14pt'>’ēā</span>",
      "<span size='14pt'>’ēé</span>",
      "<span size='14pt'>’ēü</span>",
      "<span size='14pt'>’ēĆ</span>"
    ],
    "format-plugged": "<span size='14pt'>¾░Üź</span>",
    "format-critical": "<span size='14pt'>’ü▒</span>",
    "tooltip": true,
    "tooltip-format": "{timeTo} , Now: {capacity}%",
    "tooltip-format-charging": "{timeTo}, Now: {capacity}%",
    "on-click": "notify-send 'BATTERY STATUS' \"Level: $(cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -1)%\nStatus: $(cat /sys/class/power_supply/BAT*/status 2>/dev/null | head -1)\" -u low"
  },
  "custom/powermenu": {
    "format": "<span size='13pt'>¾░Éź</span>",
    "on-click": "$HOME/.config/rofi/scripts/power-menu.sh",
    "tooltip": true,
    "tooltip-format": "Open Power Menu"
  },
  "custom/power_profile": {
    "exec": "$HOME/.config/waybar/scripts/power-profile.sh",
    "interval": 5,
    "format": "<span size='14pt'>{}</span>",
    "tooltip": false,
    "on-click": "zenith power profile cycle"
  }
}
