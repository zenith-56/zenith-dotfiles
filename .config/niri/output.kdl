// Niri Output Configuration
// =============================================================================
// Description : Output settings for the Niri compositor.
//               Configures the mode, scale, transform, and position of each
//               output device.
// =============================================================================


output "eDP-1" {
    transform "normal"
    position x=1440 y=0
}

output "HDMI-1" {
    scale 1
    transform "normal"
}


